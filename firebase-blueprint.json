{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Patient information and clinical history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "birthDate": { "type": "string" },
        "gender": { "type": "string" },
        "notes": { "type": "string" },
        "initialHistory": { "type": "string" },
        "defaultSessionValue": { "type": "number" },
        "totalPaid": { "type": "number" },
        "guardianName": { "type": "string" },
        "guardianContact": { "type": "string" },
        "medications": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "phone", "userId"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled session for a patient",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["online", "presencial"] },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled", "pending_payment"] },
        "isConfirmed": { "type": "boolean" },
        "price": { "type": "number" },
        "notes": { "type": "string" },
        "userId": { "type": "string" },
        "recurrence": { "type": "string", "enum": ["none", "weekly", "biweekly"] },
        "seriesId": { "type": "string" }
      },
      "required": ["id", "patientId", "dateTime", "userId"]
    },
    "SessionRecord": {
      "title": "SessionRecord",
      "description": "Clinical record of a therapy session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "appointmentId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "clinicalNotes": { "type": "string" },
        "evolution": { "type": "string" },
        "sessionValue": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "patientId", "appointmentId", "userId"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Clinic financial expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "value": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "category": { "type": "string", "enum": ["aluguel", "marketing", "supervisao", "outros"] },
        "userId": { "type": "string" }
      },
      "required": ["id", "description", "value", "date", "userId"]
    },
    "ClinicSettings": {
      "title": "ClinicSettings",
      "description": "General settings for the clinic",
      "type": "object",
      "properties": {
        "clinicName": { "type": "string" },
        "professionalName": { "type": "string" },
        "professionalInitials": { "type": "string" },
        "specialty": { "type": "string" },
        "defaultSessionValue": { "type": "number" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "bio": { "type": "string" }
      }
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "A blog post generated by AI or manually",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "publishedAt": { "type": "string", "format": "date-time" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "scheduled"] }
      },
      "required": ["id", "title", "content", "authorId", "status"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and permissions",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "status": { "type": "string", "enum": ["authorized", "pending", "blocked"] },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "PendingInvitation": {
      "title": "PendingInvitation",
      "description": "Pending invitation for a new team member",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "displayName", "permissions", "createdAt"]
    }
  },
  "firestore": {
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Collection of patient data"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Collection of scheduled appointments"
    },
    "/records/{recordId}": {
      "schema": "SessionRecord",
      "description": "Collection of clinical session records"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of financial expenses"
    },
    "/settings/{userId}": {
      "schema": "ClinicSettings",
      "description": "User-specific clinic settings"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and permissions"
    },
    "/invitations/{email}": {
      "schema": "PendingInvitation",
      "description": "Pending invitations for new members"
    },
    "/posts/{postId}": {
      "schema": "BlogPost",
      "description": "Collection of blog posts"
    }
  }
}
